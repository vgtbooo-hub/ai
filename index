    [LABELS.group,"group",true,"text"],
    [LABELS.direction,"direction",true,"select2"],
    [LABELS.toolType,"toolType",true,"text"],
    [LABELS.userType,"userType",true,"select3"],
    [LABELS.devMonth,"devMonth",true,"month_select"],
    [LABELS.launchMonth,"launchMonth",true,"month_select"],
    [LABELS.devHours,"devHours",true,"number"],
    [LABELS.timeSaved,"timeSaved",true,"number"],
  ];
  phaseSchema.forEach(p=>{
    cols.push([p.name+"(開始)", `phase:${p.idx}:start`, true, "date"]);
    cols.push([p.name+"(結束)", `phase:${p.idx}:end`, true, "date"]);
  });
  cols.push([LABELS.launchDate,"launchDate",true,"date"]);
  cols.push([LABELS.completed,"completed",true,"checkbox"]);
  cols.push(["","reset",false,"reset"]);

  let html = "<thead><tr>" + cols.map(c=>`<th>${c[0]}</th>`).join('') + "</tr></thead><tbody>";
  RAW.forEach(r=>{
    const current = mergeFields(r.id, false);
    html += "<tr>";
    cols.forEach(([label, field, editable, type])=>{
      if(field==='project'){
        html += `<td>${r.project}</td>`;
      } else if(field==='statusPreview'){
        const s = previewStatus(r.id);
        html += `<td><span class="stamp ${stampClass(s)}" id="admin-status-${r.id}">${s}</span></td>`;
      } else if(field==='reset'){
        html += `<td><button class="btn-danger" onclick="resetRow(${r.id})">還原</button></td>`;
      } else if(type==='number'){
        html += `<td><input type="number" step="0.1" value="${current[field]}" onchange="stageEdit(${r.id}, '${field}', this.value, 'number')"></td>`;
      } else if(type==='checkbox'){
        html += `<td><input type="checkbox" ${current[field] ? 'checked' : ''} onchange="stageEdit(${r.id}, '${field}', this.checked, 'bool')"></td>`;
      } else if(type==='select2'){
        html += `<td><select onchange="stageEdit(${r.id}, '${field}', this.value, 'text')">${['方向1','方向2'].map(g=>`<option value="${g}" ${g===current.direction?'selected':''}>${g}</option>`).join('')}</select></td>`;
      } else if(type==='select3'){
        html += `<td><select onchange="stageEdit(${r.id}, '${field}', this.value, 'text')">${['GD','廠商'].map(g=>`<option value="${g}" ${g===current.userType?'selected':''}>${g}</option>`).join('')}</select></td>`;
      } else if(type==='date'){
        let val;
        if(field.startsWith('phase:')){
          const parts = field.split(':');
          const idx = parts[1], part = parts[2];
          val = (current.phases && current.phases[idx]) ? current.phases[idx][part] : '';
        } else { val = current[field]; }
        const iso = mdToISO(val);
        html += `<td><input type="date" value="${iso}" onchange="stageEdit(${r.id}, '${field}', isoToMD(this.value), 'text')"></td>`;
      } else if(type==='month_select'){
        const opts = ["6月前", ...Array.from({length:12},(_,i)=>`${i+1}月`)];
        html += `<td><select onchange="stageEdit(${r.id}, '${field}', this.value, 'text')">${opts.map(o=>`<option value="${o}" ${o===current[field]?'selected':''}>${o}</option>`).join('')}</select></td>`;
      } else {
        html += `<td><input type="text" value="${current[field]!=null?current[field]:''}" onchange="stageEdit(${r.id}, '${field}', this.value, 'text')"></td>`;
      }
    });
    html += "</tr>";
  });
  html += "</tbody>";
  document.getElementById('adminTable').innerHTML = html;
}

