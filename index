  devHours: "開發工時(hr/月)", timeSaved: "省下GD時間", launchDate: "上線日", completed: "已完成", status: "狀態"
};

function showToast(msg, isError){
  const stack = document.getElementById('toastStack');
  if(!stack) return;
  const el = document.createElement('div');
  el.className = 'toast' + (isError ? ' error' : '');
  el.textContent = msg;
  stack.appendChild(el);
  setTimeout(()=>{ el.remove(); }, 2600);
}

function parseMD(str, year=2026){
  if(!str) return null;
  const parts = String(str).split('/');
  if(parts.length < 2) return null;
  const m = parseInt(parts[0],10), d = parseInt(parts[1],10);
  if(isNaN(m) || isNaN(d)) return null;
  return new Date(year, m-1, d);
}
function mdToISO(md, year=2026){
  if(!md) return '';
  const parts = String(md).split('/');
  if(parts.length < 2) return '';
  const m = String(parts[0]).padStart(2,'0'), d = String(parts[1]).padStart(2,'0');
  return `${year}-${m}-${d}`;
}
function isoToMD(iso){
  if(!iso) return '';
  const parts = iso.split('-');
  if(parts.length < 3) return '';
  return `${parseInt(parts[1],10)}/${parseInt(parts[2],10)}`;
}

// ---------------- Generalized phase-based status engine ----------------
function computeStatus(fields){
  if(fields.completed) return '已上線';
  const ld = parseMD(fields.launchDate);
  if(ld && NOW > ld) return '已上線(待確認)';
  const phases = fields.phases || [];
  for(let i=phases.length-1;i>=0;i--){
    const s = parseMD(phases[i] && phases[i].start);
    if(s && NOW >= s) return phases[i].name + '中';
  }
  return '開發中';
}
function stampClass(status){
  if(status.startsWith('已上線')) return 'stamp-released';
  if(status === '開發中') return 'stamp-dev';
  if(status.includes('修復')) return 'stamp-fix';
  return 'stamp-test';
}
function getPhaseSchemaNames(){
  return (RAW[0] && RAW[0].phases) ? RAW[0].phases.map(p=>p.name) : [];
}
function statusSortKey(status){
  if(status === '開發中') return -1;
  if(status.startsWith('已上線')) return 9999;
  const schema = getPhaseSchemaNames();
  const idx = schema.findIndex(n => status === n+'中');
  return idx>=0 ? idx : 500;
}

let overrides = {};
let DATA = [];

function applyOverrideLayer(merged, layer){
  if(!layer) return;
  Object.keys(layer).forEach(key=>{
    if(key.startsWith('phase:')){
      const parts = key.split(':');
      const idx = parseInt(parts[1],10), part = parts[2];
      if(!merged.phases) merged.phases = [];
      if(!merged.phases[idx]) merged.phases[idx] = {name:'', start:'', end:''};
      merged.phases[idx][part] = layer[key];
    } else {
      merged[key] = layer[key];
    }
  });
}
function mergeFields(id, includePending){
  const base = RAW.find(r=>r.id===id) || {};
  const merged = JSON.parse(JSON.stringify(base));
  if(!merged.phases) merged.phases = [];
  applyOverrideLayer(merged, overrides[id]);
  if(includePending) applyOverrideLayer(merged, pendingEdits[id]);
  return merged;
}
function buildData(){
  DATA = RAW.map(r => {
    const merged = mergeFields(r.id, false);
    return {...merged, status: computeStatus(merged)};
  });
}

// ---------------- Storage: Firebase (real cross-device) > Claude shared storage > local browser fallback ----------------
const FIREBASE_CONFIG = {
  apiKey: "AIzaSyDAv24UwirQ8Zustvk-ndl6Up78Gb8LN24",
  authDomain: "gd-all.firebaseapp.com",
  projectId: "gd-all",
  storageBucket: "gd-all.firebasestorage.app",
  messagingSenderId: "648543317115",
  appId: "1:648543317115:web:d58b43916cd262b898c6de"
};
const FIREBASE_ENABLED = !!(FIREBASE_CONFIG.apiKey && FIREBASE_CONFIG.projectId);
let firestoreDb = null;
let firestoreUnsubOverrides = null;
let firestoreUnsubBase = null;
let firebaseAuthReady = false;
let lastFirebaseAuthError = null;

async function ensureFirebaseAuth(){
  if(!FIREBASE_ENABLED) return false;
  try{
    if(!firebase.apps.length) firebase.initializeApp(FIREBASE_CONFIG);
    firestoreDb = firebase.firestore();
    await new Promise((resolve, reject)=>{
      const unsub = firebase.auth().onAuthStateChanged(user=>{
        if(user){ unsub(); resolve(); }
      });
      firebase.auth().signInAnonymously().catch(err=>{
        unsub();
        reject(err);
      });
    });
    firebaseAuthReady = true;
    lastFirebaseAuthError = null;
    return true;
  }catch(e){
    console.error('Firebase init/auth failed', e);
    firebaseAuthReady = false;
    lastFirebaseAuthError = (e && e.message) ? e.message : String(e);
    return false;
  }
}

let storageMode = "checking";

async function storageGet(key, shared){
  if(FIREBASE_ENABLED && firestoreDb){
    try{
      const snap = await firestoreDb.collection('ai_tool_tracker').doc(key).get();
      if(snap.exists){ return {key, value: snap.data().value, shared:true}; }
      return null;
    }catch(e){ console.error('Firestore get failed', e); return null; }
  }
  if(typeof window.storage !== 'undefined' && window.storage){
    try{ return await window.storage.get(key, shared); }
    catch(e){ return null; }
  }
  try{
    const v = localStorage.getItem('fallback_'+key);
    return v ? {key, value:v, shared} : null;
  }catch(e){ return null; }
}
async function storageSet(key, value, shared){
  if(FIREBASE_ENABLED && firestoreDb){
    try{
      await firestoreDb.collection('ai_tool_tracker').doc(key).set({value, updatedAt: Date.now()});
      return {key, value, shared:true};
    }catch(e){ console.error('Firestore set failed', e); return null; }
  }
  if(typeof window.storage !== 'undefined' && window.storage){
    try{ return await window.storage.set(key, value, shared); }
    catch(e){ console.error('window.storage set failed', e); return null; }
  }
  try{
    localStorage.setItem('fallback_'+key, value);
    return {key, value, shared};
  }catch(e){ console.error('localStorage set failed', e); return null; }
}

async function detectStorageMode(){
  if(FIREBASE_ENABLED){
    await ensureFirebaseAuth();
  }
  if(FIREBASE_ENABLED && firestoreDb && firebaseAuthReady){
    storageMode = "firebase";
  } else if(typeof window.storage !== 'undefined' && window.storage){
    storageMode = "shared";
  } else {
    storageMode = "local";
  }
  const noteMap = {
    firebase: "儲存模式：Firebase 雲端資料庫（真正跨裝置即時同步，已用匿名驗證+規則限制陌生人存取）",
    shared: "儲存模式：Claude 共用即時儲存（僅在 Claude 對話中開啟時，所有觀看者會同步）",
    local: "儲存模式：本機瀏覽器儲存（僅此電腦此瀏覽器可見，不會同步給其他人）"
  };
  let modeText = noteMap[storageMode];
  if(FIREBASE_ENABLED && !firebaseAuthReady){
    modeText += ` ⚠ 已設定 Firebase 但驗證失敗，已自動退回此模式（原因：${lastFirebaseAuthError || '未知'}）。`;
    showToast("⚠ Firebase 驗證失敗，請確認已啟用 Anonymous 登入", true);
  }
  document.getElementById('storageModeNote').textContent = modeText;
  const inline = document.getElementById('storageModeInline');
  if(inline) inline.textContent = {firebase:"Firebase 雲端同步（跨裝置）", shared:"Claude 共用即時儲存", local:"本機瀏覽器儲存（僅限此電腦）"}[storageMode];

  if(storageMode === "firebase" && firestoreDb){
    if(!firestoreUnsubOverrides){
      firestoreUnsubOverrides = firestoreDb.collection('ai_tool_tracker').doc(OVERRIDES_KEY)
        .onSnapshot(snap => {
          if(!snap.exists) return;
          const newValue = snap.data().value;
          if(JSON.stringify(overrides) !== newValue){
            try{
              overrides = JSON.parse(newValue);
              buildData(); buildSidebar(); refreshCurrentView();
              if(!document.getElementById('adminOverlay').classList.contains('hidden')) buildAdminTable();
            }catch(e){}
          }
        }, err => console.error('Firestore listen failed', err));
    }
    if(!firestoreUnsubBase){
      firestoreUnsubBase = firestoreDb.collection('ai_tool_tracker').doc(BASE_DATASET_KEY)
        .onSnapshot(snap => {
          if(!snap.exists) return;
          const newValue = snap.data().value;
          if(JSON.stringify(RAW) !== newValue){
            try{
              RAW = JSON.parse(newValue);
              buildData(); buildSidebar(); refreshCurrentView();
              if(!document.getElementById('adminOverlay').classList.contains('hidden')) buildAdminTable();
              showToast("📥 資料已更新為最新上傳版本");
            }catch(e){}
          }
        }, err => console.error('Firestore listen failed', err));
    }
  }
}

async function loadOverridesFromStorage(){
  try{
    const res = await storageGet(OVERRIDES_KEY, true);
    if(res && res.value){ overrides = JSON.parse(res.value); }
  }catch(e){}
}
async function saveOverridesToStorage(){
  const result = await storageSet(OVERRIDES_KEY, JSON.stringify(overrides), true);
  return !!result;
