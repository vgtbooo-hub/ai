document.getElementById('q').addEventListener('keydown', e=>{ if(e.key==='Enter') runQuery(); });
document.getElementById('passcodeInput').addEventListener('keydown', e=>{ if(e.key==='Enter') submitPasscode(); });

const RELEASED_WORDS = ['上線','上市','推出','發布','發佈','已完成','已開發','已开发','做完','結案','完工','正式運作','啟用','完成了'];
const NEGATION = ['未','沒','没','尚未','還沒','还没','非','不是'];
const RANKING_WORDS = ['省時','省下','排行','排名','top','最多','效益最高','貢獻最大','最有效率','最高'];
const OVERVIEW_WORDS = ['總覽','儀表板','整體','全部專案','dashboard','總表','總體','概況'];

// Returns one of:
//  {type:'single', value:'released'|'not_released'|'開發中'|<status string>}
//  {type:'ambiguous', candidates:[<status string>, ...]}
//  null (no match)
function detectStatusIntent(q){
  for(const w of RELEASED_WORDS){
    const idx = q.indexOf(w);
    if(idx !== -1){
      const before = q.slice(Math.max(0, idx-3), idx);
      const negated = NEGATION.some(n=>before.includes(n));
      return {type:'single', value: negated ? 'not_released' : 'released'};
    }
  }
  if(/開發中|進行中|製作中|施工中|趕工/.test(q)) return {type:'single', value:'開發中'};

  const statuses = [...new Set(DATA.map(d=>d.status))].filter(s=>s!=='開發中' && !s.startsWith('已上線'));

  function tryMatch(strict){
    const found = [];
    for(const status of statuses){
      const base = status.replace(/中$/,'');
      if(q.includes(base)){ found.push(status); continue; }
      let frags = base.match(/v1|v2|修復|內測|前置|處理|第[一二三1-9]輪/gi) || [];
      if(!strict) frags = frags.filter(f=>!/^第[一二三1-9]輪$/.test(f)); // relaxed: ignore round-number modifier
      if(frags.length && frags.every(f=>q.toLowerCase().includes(String(f).toLowerCase()))) found.push(status);
    }
    return found;
  }
  // strict pass first (handles precise queries like "第2輪修復" unambiguously);
  // if nothing matches precisely, relax and drop the round-number requirement so a
  // generic query like "修復中" correctly surfaces ALL matching rounds as candidates
  // to ask the user about, instead of silently matching zero or guessing one.
  let matches = tryMatch(true);
  if(matches.length === 0) matches = tryMatch(false);

  if(matches.length === 0) return null;
  if(matches.length === 1) return {type:'single', value: matches[0]};
  return {type:'ambiguous', candidates: matches};
}
function bigrams(s){ const arr=[]; for(let i=0;i<s.length-1;i++) arr.push(s.substr(i,2)); return arr; }
function fuzzyScore(a,b){
  const A=bigrams(a), B=bigrams(b);
  if(!A.length || !B.length) return 0;
  let score=0; A.forEach(x=>{ if(B.includes(x)) score++; });
  return score;
}
function findMonths(q){
  const found = [];
  const re = /(\d{1,2})\s*月/g;
  let m;
  const validMonths = [...new Set(DATA.flatMap(d=>[d.devMonth,d.launchMonth]))];
  while((m = re.exec(q)) !== null){
    const mon = m[1]+'月';
    if(validMonths.includes(mon)) found.push(mon);
  }
  return found;
}

function runQuery(){
  const q = document.getElementById('q').value.trim();
  lastQueryText = q;
  if(!q){ renderOverview(); return; }
  activeFilters = { months: new Set(), statuses: new Set(), group: null };
  refreshSidebarActive();

  if(RANKING_WORDS.some(w=>q.includes(w))){
    renderRanking(q);
    showToast("🔍 查詢完成");
    return;
  }

  const qUpper = q.toUpperCase();
  const projMatches = DATA.filter(d => d.project.toUpperCase().includes(qUpper) || qUpper.includes(d.project.toUpperCase()));
  if(projMatches.length === 1){
    renderSingleProject(projMatches[0]);
    showToast("🔍 查詢完成");
    return;
  }
  if(projMatches.length > 1){
    renderResult(projMatches, `專案關鍵字「${q}」`, q);
    showToast(`🔍 查詢完成，共找到 ${projMatches.length} 個相關專案`);
    return;
  }

  if(OVERVIEW_WORDS.some(w=>q.includes(w))){
    renderOverview();
    showToast("🔍 查詢完成");
    return;
  }

  let filtered = DATA;
  let filterDesc = [];
  let matchedSomething = false;

  const months = findMonths(q);
  if(months.length){
    filtered = filtered.filter(d=> months.includes(d.devMonth) || months.includes(d.launchMonth));
    filterDesc.push(months.join('/'));
    matchedSomething = true;
  }

  const statusIntent = detectStatusIntent(q);
  if(statusIntent && statusIntent.type === 'ambiguous'){
    showClarifyModal(q, statusIntent.candidates);
    return;
  }
  if(statusIntent){
    const v = statusIntent.value;
    if(v === 'not_released'){
      filtered = filtered.filter(d=>!d.status.startsWith('已上線'));
      filterDesc.push('未上線');
    } else if(v === 'released'){
      filtered = filtered.filter(d=>d.status.startsWith('已上線'));
      filterDesc.push('已上線');
    } else {
      filtered = filtered.filter(d=>d.status===v);
      filterDesc.push(v);
    }
    matchedSomething = true;
  }

  const groupsPresent = [...new Set(DATA.map(d=>d.group).filter(Boolean))];
  const groupMatch = groupsPresent.find(g => q.toUpperCase().includes(g.toUpperCase()));
  if(groupMatch){
    filtered = filtered.filter(d=>d.group===groupMatch);
    filterDesc.push(groupMatch+'組');
    matchedSomething = true;
  }

  if(!matchedSomething){
    showNoMatchModal(q);
    return;
  }
  renderResult(filtered, filterDesc.join(' + ') || '自訂查詢', q);
  showToast("🔍 查詢完成");
}

function showClarifyModal(q, candidates){
  document.getElementById('modalTitle').textContent = "🤔 請問您是指哪一個？";
  document.getElementById('modalDesc').textContent = `「${q}」目前對應到 ${candidates.length} 個可能的狀態，麻煩選一個，我才能給您正確答案：`;
  const options = candidates.map(status => ({
    label: status,
    action: () => renderResult(DATA.filter(d=>d.status===status), status, q)
  }));
  options.push({
    label: `以上全部都要看（${candidates.join(' + ')}）`,
    action: () => renderResult(DATA.filter(d=>candidates.includes(d.status)), candidates.join('+'), q)
  });
  window.__modalActions = options.map(o=>o.action);
  document.getElementById('modalOptions').innerHTML = options.map((o,i)=>
    `<button class="modal-opt" onclick="window.__modalActions[${i}](); closeNoMatchModal(); showToast('🔍 查詢完成');">${o.label}</button>`
  ).join('');
  document.getElementById('noMatchModal').classList.remove('hidden');
}

