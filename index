    if(res && res.value && res.value !== JSON.stringify(RAW)){
      const parsed = JSON.parse(res.value);
      if(Array.isArray(parsed) && parsed.length){ RAW = parsed; changed = true; }
    }
  }catch(e){}
  const beforeOv = JSON.stringify(overrides);
  await loadOverridesFromStorage();
  if(JSON.stringify(overrides) !== beforeOv) changed = true;
  if(changed){
    buildData(); buildSidebar(); refreshCurrentView();
    if(!document.getElementById('adminOverlay').classList.contains('hidden')) buildAdminTable();
  }
  return changed;
}
async function manualRefresh(){
  showToast("🔄 檢查中...");
  const changed = await pollForUpdates();
  showToast(changed ? "🔄 已更新為最新資料" : "🔄 已是最新資料");
}

async function init(){
  const baseDateEl = document.getElementById('baseDateLabel');
  if(baseDateEl) baseDateEl.textContent = `${NOW.getFullYear()}/${String(NOW.getMonth()+1).padStart(2,'0')}/${String(NOW.getDate()).padStart(2,'0')}`;
  await detectStorageMode();
  await loadBaseDatasetFromStorage();
  await loadOverridesFromStorage();
  buildData();
  buildSidebar();
  renderOverview();
  setInterval(pollForUpdates, 3000);
  document.addEventListener('visibilitychange', ()=>{ if(document.visibilityState === 'visible') pollForUpdates(); });
  window.addEventListener('focus', pollForUpdates);
}
init();
</script>
