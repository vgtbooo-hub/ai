let pendingImportRows = null;

function handleCsvUpload(e){
  const file = e.target.files[0];
  if(!file) return;
  Papa.parse(file, {
    encoding: 'UTF-8',
    complete: function(results){
      try{ processImportedCsv(results.data); }
      catch(err){ showToast('⚠ CSV 解析失敗：' + err.message, true); console.error(err); }
    },
    error: function(err){ showToast('⚠ CSV 讀取失敗', true); console.error(err); }
  });
  e.target.value = '';
}

function processImportedCsv(rawRows){
  rawRows = rawRows.filter(r=>Array.isArray(r) && r.length);
  const HEADER_KEYWORDS = ['專案','開發月','上線月','組別','方向','已完成','上線日','工具','工時','需求端'];
  let headerRowIdx = 0;
  for(let i=0;i<Math.min(6, rawRows.length);i++){
    const rowText = rawRows[i].join('');
    const matchCount = HEADER_KEYWORDS.filter(k=>rowText.includes(k)).length;
    if(matchCount >= 3){ headerRowIdx = i; break; }
  }
  const headerRow = rawRows[headerRowIdx];
  const dataRows = rawRows.slice(headerRowIdx+1).filter(r=>r.some(c=>c && String(c).trim()!==''));

  const cols = headerRow.map((h, idx)=>({idx, label: String(h||'').replace(/\s+/g,'').trim(), isContinuation: !String(h||'').trim()}));

  function findCol(predicate){
    for(const c of cols){ if(!c.isContinuation && predicate(c.label)) return c.idx; }
    return -1;
  }
  const mapping = {};
  mapping.devMonth = findCol(l=>l.includes('開發月'));
  mapping.launchMonth = findCol(l=>l.includes('上線月'));
  mapping.project = findCol(l=>l.includes('專案'));
  mapping.group = findCol(l=>l.includes('組別')||l.includes('需求端'));
  mapping.direction = findCol(l=>l.includes('方向'));
  mapping.toolType = findCol(l=>l.includes('AI工具開發'));
  mapping.userType = findCol(l=>l.includes('使用者'));
  mapping.devHours = findCol(l=>l.includes('開發工時') && !l.includes('前製') && !l.includes('協作'));
  mapping.timeSaved = findCol(l=>l.includes('省下'));
  mapping.completed = findCol(l=>l.includes('已完成'));
  mapping.launchDate = findCol(l=>l.includes('上線日'));

  const usedIdx = new Set(Object.values(mapping).filter(v=>v>=0));
  const phaseDefs = [];
  const scanStart = mapping.completed >= 0 ? mapping.completed+1 : 0;
  const scanEnd = mapping.launchDate >= 0 ? mapping.launchDate : cols.length;
  for(let i=scanStart; i<scanEnd; i++){
    if(usedIdx.has(i)) continue;
    const c = cols[i];
    if(c.isContinuation || !c.label) continue;
    const next = cols[i+1];
    if(next && next.isContinuation && !usedIdx.has(i+1)){
      phaseDefs.push({name: c.label, startIdx: i, endIdx: i+1});
      usedIdx.add(i); usedIdx.add(i+1);
    } else {
      phaseDefs.push({name: c.label, startIdx: i, endIdx: -1});
      usedIdx.add(i);
    }
  }
  const nameCount = {};
  phaseDefs.forEach(p=>{ nameCount[p.name] = (nameCount[p.name]||0)+1; p.displayName = p.name; });
  const seenCount = {};
  phaseDefs.forEach(p=>{
    if(nameCount[p.name] > 1){
      seenCount[p.name] = (seenCount[p.name]||0)+1;
      p.displayName = `${p.name}(第${seenCount[p.name]}輪)`;
    }
  });

  const get = (rowArr, i) => (i>=0 && i<rowArr.length && rowArr[i]!=null) ? String(rowArr[i]).trim() : '';
  const newRows = dataRows.map((rowArr, idx)=>{
    const row = {
      id: idx,
      devMonth: get(rowArr, mapping.devMonth),
      launchMonth: get(rowArr, mapping.launchMonth),
      project: get(rowArr, mapping.project),
      group: get(rowArr, mapping.group),
      direction: get(rowArr, mapping.direction),
      toolType: get(rowArr, mapping.toolType),
      userType: get(rowArr, mapping.userType),
      devHours: parseFloat(get(rowArr, mapping.devHours)) || 0,
      timeSaved: parseFloat(get(rowArr, mapping.timeSaved)) || 0,
      phases: phaseDefs.map(p=>({name: p.displayName, start: get(rowArr, p.startIdx), end: get(rowArr, p.endIdx)})),
      launchDate: get(rowArr, mapping.launchDate),
      completed: /^(true|1|yes|v|是|✓)$/i.test(get(rowArr, mapping.completed)),
      extra: {}
    };
    cols.forEach(c=>{
      if(c.isContinuation || !c.label) return;
      if(usedIdx.has(c.idx)) return;
      if(Object.values(mapping).includes(c.idx)) return;
      const v = get(rowArr, c.idx);
      if(v) row.extra[c.label] = v;
    });
    return row;
  }).filter(r=>r.project);

  pendingImportRows = {rows:newRows, mapping, phaseDefs, headerRowIdx, totalParsedRows: dataRows.length};
  showImportPreview();
}

function showImportPreview(){
  const {rows, mapping, phaseDefs, totalParsedRows, headerRowIdx} = pendingImportRows;
