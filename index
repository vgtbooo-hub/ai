function topGroupByCount(list){
  const m = {}; list.forEach(d=>{ m[d.group]=(m[d.group]||0)+1; });
  const entries = Object.entries(m);
  return entries.length ? entries.sort((a,b)=>b[1]-a[1])[0] : ['—',0];
}
function topGroupByEfficiency(list){
  const m = {};
  list.forEach(d=>{ if(!m[d.group]) m[d.group]={saved:0,hours:0}; m[d.group].saved+=Number(d.timeSaved||0); m[d.group].hours+=Number(d.devHours||0); });
  const arr = Object.entries(m).map(([g,v])=>[g, v.hours? v.saved/v.hours : 0]);
  return arr.length ? arr.sort((a,b)=>b[1]-a[1])[0] : ['—',0];
}
