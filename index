// ---------------- Renderers ----------------
function summarize(list){
  const total = list.length;
  const released = list.filter(d=>d.status.startsWith('已上線')).length;
  const dev = list.filter(d=>d.status==='開發中').length;
  const testing = total - released - dev;
  const sum = list.reduce((a,d)=>a+Number(d.timeSaved||0),0);
  const avg = total? sum/total : 0;
  return {total, released, dev, testing, sum, avg};
}
function updateStatCards(list, scopeLabel){
  const s = summarize(list);
  document.getElementById('scopeNote').textContent = scopeLabel;
  document.getElementById('statTotal').textContent = s.total;
  document.getElementById('statReleased').textContent = s.released;
  document.getElementById('statDev').textContent = s.dev;
  document.getElementById('statTesting').textContent = s.testing;
  document.getElementById('statAvg').textContent = s.avg.toFixed(1);
  document.getElementById('statSum').textContent = s.sum.toFixed(1);
}

